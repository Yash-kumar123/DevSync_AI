{
  "name": "@devsync/ai-service",
  "version": "0.1.0",
  "private": true,
  "description": "DevSync AI — AI inference & prompt orchestration micro-service",
  "scripts": {
    "dev": "python -m uvicorn app.main:app --reload --host 0.0.0.0 --port 5000",
    "build": "python -m compileall -q app",
    "start": "python -m uvicorn app.main:app --host 0.0.0.0 --port 5000",
    "lint": "python -m ruff check app",
    "lint:fix": "python -m ruff check app --fix",
    "format": "python -m ruff format app",
    "format:check": "python -m ruff format --check app",
    "typecheck": "python -m compileall -q app",
    "clean": "python -c \"import shutil; shutil.rmtree('.ruff_cache', ignore_errors=True)\""
  }
}
