# =============================================================================
# DevSync AI — Gateway Environment Variables
# Copy to .env and fill in real values. NEVER commit .env.
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
NODE_ENV=development
PORT=4000

# ---------------------------------------------------------------------------
# Database (Supabase PostgreSQL)
# Use PgBouncer URL for runtime, direct URL for Prisma Migrate.
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# ---------------------------------------------------------------------------
# JWT — use long, cryptographically random strings (min 64 chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ---------------------------------------------------------------------------
JWT_ACCESS_SECRET=change_me_access_secret_min_64_chars_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_REFRESH_SECRET=change_me_refresh_secret_min_64_chars_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Access token expires quickly; refresh token lasts longer.
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---------------------------------------------------------------------------
# AI Service & Redis
# ---------------------------------------------------------------------------
AI_SERVICE_URL=https://devsync-ai-service.onrender.com
REDIS_URL=rediss://default:YOUR_UPSTASH_PASSWORD@genuine-snipe-174181.upstash.io:6379

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000
