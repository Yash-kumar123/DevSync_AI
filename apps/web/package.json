{
  "name": "@devsync/web",
  "version": "0.1.0",
  "private": true,
  "description": "DevSync AI — Vite + React 19 frontend application",
  "type": "module",
  "scripts": {
    "dev": "vite --port 3000",
    "build": "tsc -b && vite build",
    "preview": "vite preview --port 3000",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json,md}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rimraf dist .turbo coverage"
  },
  "dependencies": {
    "@devsync/shared-config": "*",
    "@devsync/shared-types": "*",
    "@devsync/shared-ui": "*",
    "@monaco-editor/react": "^4.7.0",
    "@tanstack/react-query": "^5.66.8",
    "@tanstack/react-query-devtools": "^5.66.8",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "axios": "^1.8.1",
    "framer-motion": "^12.4.7",
    "monaco-editor": "^0.56.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hot-toast": "^2.5.2",
    "react-icons": "^5.7.0",
    "react-router-dom": "^7.2.0",
    "socket.io-client": "^4.8.3",
    "y-monaco": "^0.1.6",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.31",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.7.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.7.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.9",
    "globals": "^15.8.0",
    "postcss": "^8.4.40",
    "prettier": "^3.3.3",
    "rimraf": "^5.0.9",
    "tailwindcss": "^3.4.7",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.0.0",
    "vite": "^5.3.4",
    "vitest": "^2.0.4"
  }
}
