# =============================================================================
# DevSync AI — .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Environment & secrets
# ---------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key

# ---------------------------------------------------------------------------
# Dependencies
# ---------------------------------------------------------------------------
node_modules/
.pnp
.pnp.js

# ---------------------------------------------------------------------------
# Build outputs
# ---------------------------------------------------------------------------
dist/
build/
out/
.next/
.nuxt/
.output/
*.tsbuildinfo
*.d.ts.map

# ---------------------------------------------------------------------------
# Turborepo
# ---------------------------------------------------------------------------
.turbo/
.turbo-cache/

# ---------------------------------------------------------------------------
# Testing
# ---------------------------------------------------------------------------
coverage/
.nyc_output/
test-results/
playwright-report/
e2e-results/

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ---------------------------------------------------------------------------
# OS artefacts
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini
.Spotlight-V100
.Trashes
ehthumbs.db

# ---------------------------------------------------------------------------
# IDEs & editors
# ---------------------------------------------------------------------------
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.vscode/settings.json
.vscode/launch.json
!.vscode/extensions.json

# ---------------------------------------------------------------------------
# Docker volumes & local infra
# ---------------------------------------------------------------------------
docker/volumes/
docker/data/

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
*.orig
*.bak
*.timestamp-*.mjs
*.timestamp-*.js
