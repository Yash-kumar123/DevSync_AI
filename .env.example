# =============================================================================
# DevSync AI — Environment Variables Example
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control.
# =============================================================================

# ---------------------------------------------------------------------------
# General
# ---------------------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=debug

# ---------------------------------------------------------------------------
# Turborepo Remote Cache (optional — Vercel Remote Cache or self-hosted)
# ---------------------------------------------------------------------------
TURBO_TOKEN=
TURBO_TEAM=
TURBO_REMOTE_ONLY=false

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_USER=devsync
POSTGRES_PASSWORD=devsync_secret
POSTGRES_DB=devsync_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}

# ---------------------------------------------------------------------------
# MinIO / S3-compatible object storage
# ---------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_secret
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=devsync-assets
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin_secret
S3_REGION=us-east-1

# ---------------------------------------------------------------------------
# Web App (apps/web)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_GATEWAY_WS_URL=ws://localhost:4000
NEXT_PUBLIC_GATEWAY_HTTP_URL=http://localhost:4000

# ---------------------------------------------------------------------------
# Gateway Service (apps/gateway)
# ---------------------------------------------------------------------------
GATEWAY_PORT=4000
GATEWAY_HOST=0.0.0.0

# ---------------------------------------------------------------------------
# AI Service (apps/ai-service)
# ---------------------------------------------------------------------------
AI_SERVICE_PORT=5000
AI_SERVICE_HOST=0.0.0.0
# Placeholder — replace with real keys per provider
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_AI_API_KEY=...
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# ---------------------------------------------------------------------------
# JWT / Auth (placeholder — fill when auth is implemented)
# ---------------------------------------------------------------------------
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000
