{
  "name": "@devsync/shared-config",
  "version": "0.1.0",
  "private": false,
  "description": "DevSync AI — shared ESLint, Prettier, Jest, and Vitest configurations",
  "type": "commonjs",
  "main": "./index.js",
  "exports": {
    ".": "./index.js",
    "./eslint/base": "./eslint/base.js",
    "./eslint/node": "./eslint/node.js",
    "./prettier": "./prettier/index.js",
    "./package.json": "./package.json"
  },
  "files": [
    "index.js",
    "eslint/",
    "prettier/"
  ],
  "scripts": {
    "lint": "echo 'No linting for config package'",
    "format": "prettier --write \"**/*.{js,json}\"",
    "format:check": "prettier --check \"**/*.{js,json}\"",
    "clean": "echo 'Nothing to clean'"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.22.0",
    "@typescript-eslint/parser": "^8.22.0",
    "eslint": "^9.19.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-react": "^7.34.3",
    "eslint-plugin-react-hooks": "^5.2.0",
    "prettier": "^3.3.2"
  }
}
