{
  "name": "@devsync/shared-config",
  "version": "0.1.0",
  "private": false,
  "description": "DevSync AI — shared ESLint, Prettier, Jest, and Vitest configurations",
  "type": "commonjs",
  "main": "./index.js",
  "exports": {
    ".": "./index.js",
    "./eslint/base": "./eslint/base.js",
    "./eslint/next": "./eslint/next.js",
    "./eslint/node": "./eslint/node.js",
    "./prettier": "./prettier/index.js",
    "./jest/base": "./jest/base.js",
    "./vitest/base": "./vitest/base.js"
  },
  "files": [
    "index.js",
    "eslint/",
    "prettier/",
    "jest/",
    "vitest/"
  ],
  "scripts": {
    "lint": "echo 'No linting for config package'",
    "format": "prettier --write \"**/*.{js,json}\"",
    "format:check": "prettier --check \"**/*.{js,json}\"",
    "clean": "echo 'Nothing to clean'"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.14.1",
    "@typescript-eslint/parser": "^7.14.1",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.5",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-react": "^7.34.3",
    "eslint-plugin-react-hooks": "^4.6.2",
    "prettier": "^3.3.2"
  }
}
